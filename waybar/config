{
    "layer": "top",
    "height": 44,
    "spacing": 8,

    "modules-left": [
        "custom/arch",
        "cpu",
        "memory",
        "wlr/taskbar"
    ],

    "modules-center": [
        "hyprland/workspaces"
    ],

    "modules-right": [
        "mpris",
        "backlight",
        "wireplumber",
        "network",
        "battery",
        "clock"
    ],

    "mpris": {
        "player": "spotify",
        "format": "≤░ΥΘ {title} έΑΦ {artist}",
        "format-paused": "≤░Πν {title} έΑΦ {artist}",
        "max-length": 40
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "icon-theme": "hicolor",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "custom/arch": {
        "format": "≤░μΘ",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "έΩΠ",
        "persistent-workspaces": {
            "*": 5
        }
    },

    "cpu": {
        "format": "≤░╗ι {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "≤░Ξδ {used:0.1f}G"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["≤░Δγ", "≤░Δδ", "≤░Δε", "≤░Δζ", "≤░Δη", "≤░Δθ", "≤░Δι"]
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "≤░ΨΒ muted",
        "format-icons": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
    },

    "network": {
        "format-wifi": "≤░νρ {essid}",
        "format-ethernet": "≤░ΙΑ {ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr}\nStrength: {signalStrength}%",
        "format-linked": "≤░ΙΑ (No IP)",
        "format-disconnected": "≤░νφ Disconnected"
    },

    "battery": {
        "bat": "BAT0",
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "≤░γξ {capacity}%",
        "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
        "tooltip-format": "{time} remaining"
    },

    "clock": {
        "format": "≤░ξΦ {:%H:%M}",
        "format-alt": "≤░Δφ {:%Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    }
}
