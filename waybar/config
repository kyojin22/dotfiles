{
    "layer": "top",
    "height": 44,
    "spacing": 8,

    "modules-left": [
        "custom/arch",
        "cpu",
        "memory",
        "wlr/taskbar"
    ],

    "modules-center": [
        "hyprland/workspaces"
    ],

    "modules-right": [
        "mpris",
        "backlight",
        "wireplumber",
        "network",
        "clock"
    ],

    "mpris": {
        "player": "spotify",
        "format": "󰓇 {title} — {artist}",
        "format-paused": "󰏤 {title} — {artist}",
        "max-length": 40
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "custom/arch": {
        "format": "󰣇",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "●",
        "persistent-workspaces": {
            "*": 5
        }
    },

    "cpu": {
        "format": "󰻠 {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "󰍛 {used:0.1f}G"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃚", "󰃛", "󰃜", "󰃝", "󰃞", "󰃟", "󰃠"]
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "󰖁 muted",
        "format-icons": ["󰕿", "󰖀", "󰕾"]
    },

    "network": {
        "format-wifi": "󰤨 {essid}",
        "format-ethernet": "󰈀 {ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr}\nStrength: {signalStrength}%",
        "format-linked": "󰈀 (No IP)",
        "format-disconnected": "󰤭 Disconnected"
    },

    "clock": {
        "format": "󰥔 {:%H:%M}",
        "format-alt": "󰃭 {:%Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    }
}
